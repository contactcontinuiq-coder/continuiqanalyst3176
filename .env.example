# Resend — for transactional email
# Get your key at https://resend.com/api-keys (starts with "re_")
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Google Sheets webhook — Apps Script web app URL bound to your audit sheet
# See README.md "Setting up the audit pipeline" for how to deploy.
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycb.../exec

# Optional shared secret the Apps Script can verify (any random string)
SHEETS_WEBHOOK_SECRET=
